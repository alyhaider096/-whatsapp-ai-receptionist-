# Postgres
POSTGRES_USER=receptionist
POSTGRES_PASSWORD=receptionist
POSTGRES_DB=receptionist
DATABASE_URL=postgresql+asyncpg://receptionist:receptionist@localhost:5432/receptionist

# Redis / ARQ
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Fernet key for encrypting Meta tokens + LLM keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Meta / WhatsApp Cloud API (test number values from the Meta developer app)
META_APP_SECRET=
META_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v25.0

# Default LLM (LiteLLM model string). Swap the model name freely; nothing in
# the code depends on a specific provider or model.
# Examples: "openai/gpt-4o-mini", "openai/gpt-5-nano", "gemini/gemini-1.5-flash"
DEFAULT_LLM_MODEL=openai/gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_TRANSCRIPTION_MODEL=whisper-1
# No app-wide OpenAI key -- each tenant sets their own LLM API key from the
# dashboard's Agent Settings page (stored encrypted in llm_configs).

# Owner handoff email notifications -- optional. Leave SMTP_HOST blank to
# skip sending (worker logs and continues, never breaks the handoff itself).
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, an "app password"
# (not your normal password) as SMTP_PASSWORD.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
APP_BASE_URL=http://localhost:3000

# Google Sheets appointment booking -- optional. Leave blank to skip (the
# booking tools are never registered). One shared Service Account for the
# whole app; each tenant shares their own Sheet with its email and pastes
# the Spreadsheet ID into the dashboard (Integrations page). Paste the full
# JSON key content as a single line here.
GOOGLE_SERVICE_ACCOUNT_JSON=

ENVIRONMENT=development
